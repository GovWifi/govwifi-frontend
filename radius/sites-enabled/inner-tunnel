server inner-tunnel {

    authorize {
        filter_username
        eap
        if (ok) {
            govlogger
            return
        }
        govlogger
        rest
    }

    authenticate {
        Auth-Type MS-CHAP {
            mschap
        }
        eap
        govlogger
    }

    post-auth {
        govlogger
        redundant {
            rest
            ok
        }

        Post-Auth-Type REJECT {
            govlogger
            redundant {
                rest
                fail
            }
        }
    }

    pre-proxy {
    }

    post-proxy {
        eap
    }
}
