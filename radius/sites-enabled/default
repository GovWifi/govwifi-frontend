server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
        limit {
            max_connections = 64
            lifetime = 0
            idle_timeout = 30
        }
    }

    listen {
        ipaddr = *
        port = 0
        type = acct
        limit {
        }
    }

    authorize {
        eap {
            ok = return
        }
    }

    authenticate {
        eap
    }

    preacct {
    }

    accounting {
    }

    session {
    }

    post-auth {
        update {
            &reply: += &session-state:
        }

        if (EAP-Type == TLS || EAP-Type == PEAP || EAP-Type == TTLS) {
            redundant {
                rest
                ok
            }
        }

        Post-Auth-Type REJECT {
          redundant {
            rest
            fail
          }
        }
    }

    pre-proxy {
    }

    post-proxy {
        eap
    }
}
