
server default {
  listen {
    type = auth
    
    
    ipaddr = *
    
    port = 0
    
    
    
    limit {
      max_connections = 64
      
      
      lifetime = 0
      
      idle_timeout = 30
    }
  }
  
  listen {
    ipaddr = *
    port = 0
    type = acct
    
    limit {
      
    }
  }
  
  authorize {
    eap
    if (EAP-Type != "PEAP" && EAP-Type != "MSCHAPv2") {
	    govlogger
    }
    if (ok) {
      ok = return
    }
  }
  
  authenticate {
    eap
  }
  
  preacct {
  }
  
  accounting {
  }
  
  post-auth {
    if (EAP-Type == TLS) {
      govlogger
      redundant {
        rest
        ok
      }
    }
    
    Post-Auth-Type REJECT {
      if (EAP-Type != "PEAP" && EAP-Type != "MSCHAPv2") {
        govlogger
      }
      redundant {
        rest
        fail
      }
    }
  }
  
  
  pre-proxy {
  }
  
  post-proxy {
    eap
  }
}
